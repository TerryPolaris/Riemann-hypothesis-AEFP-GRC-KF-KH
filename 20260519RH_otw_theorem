```lean
import Mathlib

namespace RHOpticalAtlas

noncomputable section
open Classical

/-- Alpha coordinate: distance from the critical line. -/
def alpha (s : ℂ) : ℝ :=
  s.re - (1 / 2 : ℝ)

/-- Alpha is zero exactly on the critical line. -/
theorem alpha_zero_iff_critical (s : ℂ) :
    alpha s = 0 ↔ s.re = (1 / 2 : ℝ) := by
  unfold alpha
  constructor
  · intro h
    linarith
  · intro h
    linarith

/-- A point explicitly placed on the critical line has alpha zero. -/
theorem alpha_mk_critical (t : ℝ) :
    alpha (Complex.mk (1 / 2 : ℝ) t) = 0 := by
  simp [alpha]

/-- Quadratic small-alpha debt approximation. -/
def Dquad (a U : ℝ) : ℝ :=
  (U ^ 2 / 3) * a ^ 2

theorem Dquad_nonneg (a U : ℝ) :
    0 ≤ Dquad a U := by
  unfold Dquad
  positivity

theorem Dquad_pos {a U : ℝ} (ha : a ≠ 0) (hU : U ≠ 0) :
    0 < Dquad a U := by
  unfold Dquad
  have hU2 : 0 < U ^ 2 := sq_pos_of_ne_zero hU
  have ha2 : 0 < a ^ 2 := sq_pos_of_ne_zero ha
  positivity

theorem Dquad_eq_zero_iff {a U : ℝ} (hU : U ≠ 0) :
    Dquad a U = 0 ↔ a = 0 := by
  constructor
  · intro h
    by_contra ha
    have hp : 0 < Dquad a U := Dquad_pos ha hU
    linarith
  · intro ha
    simp [Dquad, ha]

/-- Finite window count packet. -/
structure WindowCounts where
  total : Nat
  line : Nat

def OffCount (w : WindowCounts) : Nat :=
  w.total - w.line

theorem offCount_zero_of_eq (w : WindowCounts) (h : w.total = w.line) :
    OffCount w = 0 := by
  simp [OffCount, h]

/-- A finite numerical certificate.
This is evidence, not RH proof. -/
structure FiniteZeroCertificate where
  n : Nat
  gamma : ℝ
  bracket_lo : ℝ
  bracket_hi : ℝ
  root_on_critical_line : Prop
  unique_root_in_bracket : Prop
  xi_centered_single_well : Prop
  window_counts_closed : Prop

theorem certificate_accepts_alpha_zero
    (c : FiniteZeroCertificate)
    (hroot : c.root_on_critical_line) :
    alpha (Complex.mk (1 / 2 : ℝ) c.gamma) = 0 := by
  simp [alpha]

theorem certificate_window_closed
    (c : FiniteZeroCertificate)
    (h : c.window_counts_closed) :
    c.window_counts_closed := h

end

end RHOpticalAtlas
